# =============================================================================
# Git Attributes — agentic-rag-ecommerce
# Ensures consistent line endings and diff behavior across platforms.
# =============================================================================

# Default: auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# =============================================================================
# Source Code — explicitly text, always LF
# =============================================================================
*.py        text eol=lf
*.pyi       text eol=lf
*.ipynb     text eol=lf

# Web / template
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.jsx       text eol=lf
*.tsx       text eol=lf

# =============================================================================
# Configuration & Data Files
# =============================================================================
*.toml      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.env       text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.conf      text eol=lf

# =============================================================================
# Documentation & Markdown
# =============================================================================
*.md        text eol=lf
*.txt       text eol=lf
*.rst       text eol=lf

# =============================================================================
# Shell Scripts
# =============================================================================
*.sh        text eol=lf
*.bash      text eol=lf
Makefile    text eol=lf

# =============================================================================
# Docker
# =============================================================================
Dockerfile*     text eol=lf
*.dockerfile    text eol=lf
.dockerignore   text eol=lf

# =============================================================================
# SQL
# =============================================================================
*.sql       text eol=lf

# =============================================================================
# GraphQL
# =============================================================================
*.graphql   text eol=lf
*.gql       text eol=lf

# =============================================================================
# Binary Files — never diff or convert line endings
# =============================================================================
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.webp      binary

*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary
*.tgz       binary
*.rar       binary
*.7z        binary

*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.eot       binary

*.pyc       binary
*.pyd       binary
*.so        binary

# =============================================================================
# Git LFS (Large File Storage) — if needed for large model/data files
# =============================================================================
# Uncomment the lines below if you store large files in LFS:
# *.pt      filter=lfs diff=lfs merge=lfs -text
# *.bin     filter=lfs diff=lfs merge=lfs -text
# *.pkl     filter=lfs diff=lfs merge=lfs -text
# *.onnx    filter=lfs diff=lfs merge=lfs -text

# =============================================================================
# Diff Drivers — improve readability of diffs for specific file types
# =============================================================================
*.py        diff=python
*.md        diff=markdown
*.ipynb     diff=jupyternotebook
