flowchart TD
    subgraph PARENT["Parent Graph — StateGraph(AgentState)"]
        direction TB

        START([HTTP Request]) --> profiler
        START -->|if not title_generated| title_gen

        title_gen["TitleGenerationNode\nasync def\nLLM: TITLE_MODEL"]
        title_gen --> TEND([END])

        profiler["ProfilerNode\nasync def\nLoad + update UserProfile\nLLM: SUMMARIZE_MODEL\nStore: AsyncPostgresStore"]
        profiler --> summarize

        summarize["SummarizeNode\nasync def\nno-op if len(messages) < threshold\nLLM: SUMMARIZE_MODEL\nRemoveMessage + summary update"]
        summarize --> orchestrate

        orchestrate["OrchestratorNode\nasync def + tool binding\nupdate_intent tool\nLLM: ORCHESTRATOR_MODEL\nChecks remaining_steps"]

        orchestrate -->|need_product_search\npriority: always first| rag
        orchestrate -->|need_trend_info| trend
        orchestrate -->|sufficient / clarification_needed\nout_of_scope / fallback| synth

        subgraph RAG["run_product_rag — ProductRAGAgent subgraph (StateGraph)"]
            direction TB
            r1["prepare_query_node\nLLM: ORCHESTRATOR_MODEL\nStructured output: query + filters\nInput: messages + summary + user_profile"]
            r2["hybrid_search_node\nLlamaIndex + Qdrant\ndense + sparse BM25\nRelative Score Fusion"]
            r3["llm_postprocess_node\nLLM: RERANK_MODEL\nFilter top-K product IDs\nMap back to ProductPayload"]
            r1 --> r2 --> r3
        end

        subgraph TREND["run_trend_scout — TrendScoutNode (create_agent)"]
            direction TB
            t1["Dynamic SystemMessage\n(summary + user_profile\n+ retrieved_products)"]
            t2["create_agent ReAct loop\nLLM: ORCHESTRATOR_MODEL\ntools: tavily_search / duckduckgo_search\nOutput: TrendScoutOutput\n(trend_summary + image_prompt)"]
            t1 --> t2
        end

        rag --> orchestrate
        trend --> orchestrate

        synth["ResponseGeneratorNode\nasync def + SSE streaming\nLLM: RESPONSE_MODEL\nInjects: user_profile + products\n+ trend_summary + summary"]

        synth -->|if image conditions met| imggen
        synth --> END2([END + SSE done])

        imggen["ImageGenerationNode\nasync def — parallel branch\nDALL-E API + S3 upload\nSSE: image_ready event\nQuota: Valkey counter"]
        imggen --> END3([END])
    end

    subgraph STORAGE["Persistence Layer"]
        pg[("AsyncPostgresSaver\nAgentState checkpoints\nper thread_id")]
        store[("AsyncPostgresStore\nUserProfile\nper user_id — cross-thread")]
        qdrant[("Qdrant\nHybrid vectors\ndense + sparse BM25")]
        valkey[("Valkey/Redis\nRate limiting\nResponse cache\nImage quota")]
    end

    profiler <-->|get/put UserProfile| store
    PARENT <-->|checkpoint per turn| pg
    RAG <-->|hybrid search| qdrant
    synth <-->|response cache| valkey
    imggen <-->|image quota| valkey
