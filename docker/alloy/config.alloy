// docker/alloy/config.alloy
// Phase 16 — Log pipeline (D5, D8, D9; tactical D16.3, D16.4).
// Phase 17 — Metrics expansion (D2, D7, D10; tactical D17.1-D17.9).
// Replaces docker/promtail/ + docker/promtail/config.yaml and
// replaces every scrape_configs entry in docker/prometheus/prometheus.yml.
// Reads container stdout via Docker socket; ships structured logs to Loki.
// Scrapes 5 /metrics endpoints and remote_writes to Prometheus.

// ─── Container discovery ─────────────────────────────────────────────────────
// One discovery target per running container in the agentic-rag compose
// project. The Docker socket is mounted read-only into the Alloy container.
discovery.docker "all_containers" {
  host = "unix:///var/run/docker.sock"
}

// ─── Label extraction ────────────────────────────────────────────────────────
// Promote two labels to every log line before it enters loki.source.docker:
//   service    = the docker compose service name (e.g. "app", "celery-worker")
//   container  = the full container name (e.g. "agentic-rag-app")
// The compose service label is set automatically by docker compose for
// every service in the project.
discovery.relabel "alloy_logs" {
  targets = discovery.docker.all_containers.targets

  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    target_label  = "service"
  }

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }
}

// ─── Source: read container stdout ───────────────────────────────────────────
// loki.source.docker tails the JSON log file the docker daemon writes for
// each container. We override the default 60s refresh interval to 5s so
// new containers (e.g. ephemeral celery-worker restarts) show up quickly.
loki.source.docker "alloy_logs" {
  host             = "unix:///var/run/docker.sock"
  targets          = discovery.relabel.alloy_logs.output
  refresh_interval = "5s"
  forward_to       = [loki.process.parse_logs.receiver]
}

// ─── Process: parse structlog JSON and promote to Loki labels ────────────────
// structlog envelope (from app/observability/logging.py):
//   {"event": "...", "level": "info", "timestamp": "2026-06-20T...",
//    "correlation_id": "<uuid>", "thread_id": "<uuid>", "user_id": "...",
//    "endpoint": "stream_run", "logger": "app.api.chat", ...}
// Fields set via bind_contextvars at the API boundary (chat.py:132-137) flow
// through automatically. The level field comes from
// structlog.stdlib.add_log_level.
loki.process "parse_logs" {
  forward_to = [loki.write.loki.receiver]

  stage.json {
    expressions = {
      correlation_id = "correlation_id",
      thread_id      = "thread_id",
      user_id        = "user_id",
      level          = "level",
      endpoint       = "endpoint",
    }
  }

  // D16.4 — promote parsed fields to Loki labels. The label keys on the
  // left are what LogQL queries will reference. Empty value on the right
  // means "look up the extracted map key with the same name".
  stage.labels {
    values = {
      correlation_id = "",
      thread_id      = "",
      user_id        = "",
      level          = "",
    }
  }

  // `endpoint` is high-cardinality (one value per route). Per the design
  // doc §5.2 it stays as structured metadata, not a Loki label, to bound
  // label cardinality. It is still visible when you click into a log line
  // in Grafana.
  stage.structured_metadata {
    values = {
      endpoint = "endpoint",
    }
  }
}

// ─── Sink: push to Loki ──────────────────────────────────────────────────────
loki.write "loki" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}

// ─── Metrics: scrape 5 targets and remote_write to Prometheus ───────────────
// D2, D7 — Alloy is the single collector for metrics. Prometheus becomes
// pure storage + query backend. 5 targets on the agentic-rag Docker
// network. Scrape interval matches the old Prometheus interval (D17.9).
// forward_to chains every scrape job into the single
// prometheus.remote_write receiver below.

prometheus.scrape "agentic_rag_app" {
  targets         = [{"__address__" = "app:8080"}]
  job_name        = "agentic-rag-app"
  metrics_path    = "/metrics"
  scrape_interval = "15s"
  forward_to      = [prometheus.remote_write.default.receiver]
}

prometheus.scrape "qdrant" {
  targets         = [{"__address__" = "qdrant:6333"}]
  job_name        = "qdrant"
  metrics_path    = "/metrics"
  scrape_interval = "15s"
  forward_to      = [prometheus.remote_write.default.receiver]
}

prometheus.scrape "rabbitmq" {
  targets         = [{"__address__" = "rabbitmq:15692"}]
  job_name        = "rabbitmq"
  metrics_path    = "/metrics"
  scrape_interval = "15s"
  forward_to      = [prometheus.remote_write.default.receiver]
}

prometheus.scrape "redis_exporter" {
  targets         = [{"__address__" = "redis-exporter:9121"}]
  job_name        = "redis-exporter"
  metrics_path    = "/metrics"
  scrape_interval = "15s"
  forward_to      = [prometheus.remote_write.default.receiver]
}

prometheus.scrape "postgres_exporter" {
  targets         = [{"__address__" = "postgres-exporter:9187"}]
  job_name        = "postgres-exporter"
  metrics_path    = "/metrics"
  scrape_interval = "15s"
  forward_to      = [prometheus.remote_write.default.receiver]
}

// Receiver — single endpoint into Prometheus. The Prometheus container
// accepts remote write at the default path POST /api/v1/write.
prometheus.remote_write "default" {
  external_labels = {
    cluster = "agentic-rag-local",
  }
  endpoint {
    url = "http://prometheus:9090/api/v1/write"
  }
}
