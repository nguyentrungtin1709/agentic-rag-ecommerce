{
  "annotations": {
    "list": []
  },
  "description": "Business Metrics — application-level counters derived from Loki (no custom Prometheus metrics per D18.1). All queries use count_over_time(...[24h]) over a 24h window. Failure counters (B2-B5) drill through to Logs Explorer for line-level inspection. Counts reflect the last 24h and update on dashboard refresh.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Chat turns (24h, approx.)",
      "description": "Approximation: counts every structlog line with endpoint=stream_run over 24h. Each chat turn emits 10-20 such lines (orchestrator dispatches, agent reasoning, tool calls, synthesize emits), so the displayed number is roughly an order of magnitude high. A single chat_run_completed log line at src/app/api/chat.py:270 would make this exact (D18.10, deferred). Drill-down opens Logs Explorer with endpoint=stream_run pre-filled so the operator can eyeball the actual rate.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "count_over_time({service=\"app\"} | endpoint=\"stream_run\" [24h])",
          "legendFormat": "approx. chat turns",
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "View stream_run logs",
          "url": "/d/pod-stylist/logs-explorer?var-service=app&var-endpoint=stream_run&from=now-24h&to=now",
          "type": "link",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Chat failures (24h)",
      "description": "Count of chat_run_graph_failed and chat_run_graph_timeout errors over the last 24h. Any non-zero value means a user request failed. Drill-down opens Logs Explorer with level=error and endpoint=stream_run.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "count_over_time({service=\"app\"} | endpoint=\"stream_run\" | level=\"error\" |~ \"chat_run_graph_(failed|timeout)\" [24h])",
          "legendFormat": "chat failures",
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "View chat failure logs",
          "url": "/d/pod-stylist/logs-explorer?var-service=app&var-level=error&var-endpoint=stream_run&from=now-24h&to=now",
          "type": "link",
          "targetBlank": false
        }
      ]
