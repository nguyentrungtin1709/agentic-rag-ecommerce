{
  "annotations": {
    "list": []
  },
  "description": "Infrastructure health — five Alloy-scraped targets (FastAPI app, Qdrant, RabbitMQ, redis-exporter, postgres-exporter) plus the standard postgres/redis/queue gauges. Backed by the five prometheus.scrape blocks in docker/alloy/config.alloy (D17.1-D17.5). Every panel is a single PromQL query against a known metric; no derived metrics. Drill-down links on the Postgres and RabbitMQ panels jump into the Logs Explorer for the same time range.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "App up",
      "description": "1 when the FastAPI app /metrics endpoint is reachable on app:8080. 0 means the Alloy scrape is failing — check the app container health and the network route.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "up{job=\"agentic-rag-app\"}",
          "legendFormat": "app",
          "refId": "A"
        }
      ]
    },
