{
  "annotations": {
    "list": []
  },
  "description": "Logs Explorer — pivot from a Loki label (correlation_id, thread_id, user_id, service, level, endpoint) to the matching structlog JSON lines. Filters chips at the top of the dashboard narrow every panel; correlation_id and thread_id textboxes let an operator paste a UUID from a LangSmith trace or a structured log line and see the full request trail across services. Backed by the loki.process pipeline in docker/alloy/config.alloy which promotes correlation_id, thread_id, user_id, level to Loki labels per D9 / D16.4.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Logs by level (last 1m rate)",
      "description": "Stacked log-line rate grouped by severity level. Always shows all levels regardless of the $level filter (the filter applies to L2 only).",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "sum"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "lines / second",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "warning"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "info"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "debug"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "sum by (level) (rate({service=\"$service\"}[1m]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Logs by service (respects $level)",
      "description": "Stacked log-line rate grouped by compose service. Always spans all services regardless of the $service filter so the operator can see cross-service traffic (e.g. spikes in celery-worker logs correlating with app logs).",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "sum"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "lines / second",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "sum by (service) (rate({service=~\".+\", level=~\"$level\"}[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Recent errors (last 15m)",
      "description": "Stream of every container stdout JSON log line with level=error. Use the dedicated errors list to spot recent 5xx-class application faults without scanning every level=warning line.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "{service=~\".+\", level=\"error\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Recent warnings (last 15m)",
      "description": "Stream of every container stdout JSON log line with level=warning. Includes transient-retry notices, rate-limit hits, generate_image_failed events, and orchestrate_unknown_intent warnings.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "{service=~\".+\", level=\"warning\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Correlation ID detail",
      "description": "Paste a correlation_id (UUID4) into the chip above to retrieve every structlog JSON line for a single request, across every container. Empty input yields no results by design. The correlation_id label is populated by structlog.bind_contextvars at src/app/api/chat.py:131-137.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "{service=~\".+\", correlation_id=~\"$correlation_id\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Thread history",
      "description": "Paste a thread_id (UUID) into the chip above to retrieve every log line associated with a single chat thread across its lifetime. Useful for reconstructing the full sequence of orchestrator dispatches and synthesize emissions.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "{service=~\".+\", thread_id=~\"$thread_id\"}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["pod-stylist", "logs"],
  "templating": {
    "list": [
      {
        "name": "DS_LOKI",
        "label": "Loki datasource",
        "type": "datasource",
        "query": "loki",
        "current": {
          "selected": false,
          "text": "Loki",
          "value": "Loki"
        },
        "hide": 0
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI}"
        },
        "query": {
          "query": "label_values({__name__=~\".+\"}, service)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "regex": "",
        "sort": 1,
        "current": {
          "selected": false,
          "text": "app",
          "value": "app"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 2
      },
      {
        "name": "level",
        "label": "Level",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI}"
        },
        "query": {
          "query": "label_values({service=\"$service\"}, level)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "regex": "",
        "sort": 1,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2
      },
      {
        "name": "correlation_id",
        "label": "Correlation ID",
        "type": "textbox",
        "query": "",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "hide": 0
      },
      {
        "name": "thread_id",
        "label": "Thread ID",
        "type": "textbox",
        "query": "",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "hide": 0
      },
      {
        "name": "user_id",
        "label": "User ID",
        "type": "textbox",
        "query": "",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "hide": 0
      },
      {
        "name": "endpoint",
        "label": "Endpoint",
        "description": "endpoint is stored as Loki structured metadata (D16.4), not a stream label, so the variable uses detected_field_values instead of label_values.",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI}"
        },
        "query": {
          "query": "detected_field_values({service=\"$service\"}, endpoint)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "regex": "",
        "sort": 1,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2
      }
    ]
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "timezone": "browser",
  "title": "Logs Explorer",
  "uid": "logs-explorer",
  "version": 1,
  "weekStart": ""
}